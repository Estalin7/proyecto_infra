[Unit]
Description=Restaurante CRUD Backend Application
After=network.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ app_home }}

# Environment variables
Environment="SPRING_PROFILES_ACTIVE=prod"
Environment="JAVA_OPTS=-Xms512m -Xmx1024m"

# Command to run the JAR
ExecStart=/usr/bin/java -jar {{ app_home }}/app.jar \
  --server.port={{ spring_boot_port }} \
  --logging.file.name={{ app_home }}/logs/app.log

# Restart policy
Restart=on-failure
RestartSec=10

# Security settings
NoNewPrivileges=true
PrivateTmp=true

# Resource limits
LimitNOFILE=65535

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier={{ systemd_service_name }}

[Install]
WantedBy=multi-user.target