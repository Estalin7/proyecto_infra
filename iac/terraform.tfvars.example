# terraform.tfvars.example
# Copia este archivo como terraform.tfvars y completa los valores reales.
# ⚠️ NUNCA commitees terraform.tfvars con valores reales al repositorio.

# ─── General ─────────────────────────────────────────────
aws_region      = "us-east-2"
project_name    = "restaurant-project"
environment     = "prod"

# ─── Dominio ─────────────────────────────────────────────
domain_name     = "restaurant.com"
certificate_arn = ""  # ARN del certificado ACM (us-east-1 para CloudFront)

# ─── VPC ─────────────────────────────────────────────────
vpc_cidr              = "10.2.0.0/16"
subnet_private_1_cidr = "10.2.1.0/24"
subnet_private_2_cidr = "10.2.2.0/24"

# ─── EC2 ─────────────────────────────────────────────────
ec2_instance_type = "t3.micro"
ec2_key_name      = ""  # Nombre del key pair en AWS

# ─── Aurora ──────────────────────────────────────────────
db_username = "admin"
db_password = ""  # ⚠️ Usar AWS Secrets Manager en producción

# ─── ElastiCache ─────────────────────────────────────────
redis_node_type = "cache.t3.micro"

# ─── Cognito ─────────────────────────────────────────────
cognito_user_pool_name = "restaurant-users"

# ─── S3 ──────────────────────────────────────────────────
s3_frontend_bucket_name = "restaurantfront-ptp-controlada"
