# ============================================================
# terraform.tfvars.example
# Copia este archivo como terraform.tfvars y completa los
# valores marcados con CAMBIAR_ESTO.
# NUNCA subir terraform.tfvars con valores reales al repo.
# ============================================================

project     = "restaurante-carloncho"
environment = "prod"
aws_region  = "us-east-2"

domain_name = "restaurante-carloncho.com"

vpc_cidr           = "10.2.0.0/16"
private_subnets    = ["10.2.1.0/24", "10.2.2.0/24"]
public_subnets     = ["10.2.10.0/24", "10.2.11.0/24"]
availability_zones = ["us-east-2a", "us-east-2b"]

ec2_instance_type = "t3.medium"
app_port          = 8080
health_check_path = "/actuator/health"

aurora_instance_class = "db.t3.medium"
db_name               = "restaurantdb"
db_username           = "CAMBIAR_ESTO"
db_password           = "CAMBIAR_ESTO"

redis_node_type = "cache.t3.medium"
redis_num_nodes = 1

waf_rate_limit = 2000

cf_price_class = "PriceClass_100"

lambda_artifacts_bucket = "CAMBIAR_ESTO"
telefono_cocina         = "CAMBIAR_ESTO"

sqs_visibility_timeout = 300
sqs_max_receive_count  = 3