# ============================================================
# .env.template
# Copia este archivo como .env y completa los valores.
# NUNCA subas el .env real al repositorio.
#
# Uso:
#   cp .env.template .env
#   # edita .env con tus valores reales
# ============================================================

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-2
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Proyecto ─────────────────────────────────────────────────
PROJECT_NAME=restaurante-carloncho
ENVIRONMENT=prod           # dev | qa | prod

# ── Dominio ──────────────────────────────────────────────────
DOMAIN_NAME=restaurant.com
# El ID de la Hosted Zone se puede obtener con:
#   aws route53 list-hosted-zones-by-name --dns-name $DOMAIN_NAME
HOSTED_ZONE_ID=

# ── GoDaddy API (para nameservers.sh) ────────────────────────
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ── Base de Datos (Aurora PostgreSQL) ────────────────────────
DB_USERNAME=admindb
DB_PASSWORD=CambiarEstoEnProd!
DB_NAME=restaurantdb

# ── ElastiCache Redis ────────────────────────────────────────
REDIS_AUTH_TOKEN=CambiarTokenRedis!

# ── Lambda / SNS ─────────────────────────────────────────────
# Número de teléfono de cocina en formato E.164
TELEFONO_COCINA=+51999999999

# ── Frontend (S3 + CloudFront) ───────────────────────────────
# Directorio local del build del frontend (para el deploy a S3)
FRONTEND_BUILD_DIR=./frontend/dist

# ── Terraform ────────────────────────────────────────────────
TF_VAR_FILE=prod.auto.tfvars  # dev.auto.tfvars | prod.auto.tfvars
